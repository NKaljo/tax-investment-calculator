<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tax Investment Calculator</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-stone-50 text-gray-800 font-serif leading-relaxed">

<header class="bg-[#1a2e4a] text-white px-12 py-8">
    <h1 class="text-3xl font-normal tracking-wide">Tax Investment Calculator</h1>
    <p class="mt-1 text-sm text-blue-200/75">Serbian investment tax computation — dividend &amp; capital gain</p>
</header>

<nav class="bg-[#233d5e] px-12 py-2.5 flex gap-8">
    <a href="#" class="text-blue-200 text-sm uppercase tracking-widest hover:text-white transition-colors">Home</a>
    <a href="#" class="text-blue-200 text-sm uppercase tracking-widest hover:text-white transition-colors">Dividend Tax</a>
    <a href="#" class="text-blue-200 text-sm uppercase tracking-widest hover:text-white transition-colors">Capital Gain Tax</a>
    <a href="#" class="text-blue-200 text-sm uppercase tracking-widest hover:text-white transition-colors">About</a>
</nav>

<main class="max-w-4xl mx-auto my-12 px-8">

    <section class="mb-12">
        <h2 class="text-3xl font-normal text-[#1a2e4a] mb-4">Lorem ipsum dolor sit amet</h2>
